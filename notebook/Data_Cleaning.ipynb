import pandas as pd
import numpy as np
import re
SPREADSHEET_ID = '1iZBE2xiZyqms6aJSrbzsU2IOsKpiQPq-YVXXKQsK1fw'
GID_TEST = '1781986964'
url_test = f'https://docs.google.com/spreadsheets/d/{SPREADSHEET_ID}/export?format=csv&gid={GID_TEST}'

try:
    df = pd.read_csv(url_test)
    print(f"Done")
    print(f"Total: {len(df)} data\n")
except Exception as e:
    print(f"Error: {e}")
def clean_text_skripsi(text):
    if pd.isna(text):
        return ""
    text = str(text)
    text = text.lower()
    text = re.sub(r'https?:\/\/\S+', '', text)
    text = re.sub(r'\b[a-z0-9._%+-]+@jiva\.ag\b', '[internal_email_redacted]', text)
    text = re.sub(r'\b[a-z0-9._%+-]+@[a-z0-9.-]+\.[a-z]{2,}\b', '[email_redacted]', text)
    text = re.sub(r'[^a-z0-9\s]', '', text)

    return text.strip()
col_summary = 'Summary' if 'Summary' in df.columns else 'summary'
col_description = 'Description' if 'Description' in df.columns else 'description'
df['Summary_Cleaned'] = df[col_summary].apply(clean_text_skripsi)
df['Description_Cleaned'] = df[col_description].apply(clean_text_skripsi)
df['Query_Cleaned'] = df['Summary_Cleaned'] + " " + df['Description_Cleaned']
df['Query_Cleaned'] = df['Query_Cleaned'].str.strip()

print("Done")
display(df[[col_summary, col_description, 'Query_Cleaned']].head())

df.to_csv("dataset_tiket_it_cleaned.csv", index=False)
