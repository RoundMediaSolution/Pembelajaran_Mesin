import pandas as pd
import requests
from groq import Groq
GROQ_API_KEY = "[your groq api key]"
SPREADSHEET_ID = "1iZBE2xiZyqms6aJSrbzsU2IOsKpiQPq-YVXXKQsK1fw"
GID = "689446936"
client = Groq(api_key=GROQ_API_KEY)
url = f"https://docs.google.com/spreadsheets/d/{SPREADSHEET_ID}/export?format=csv&gid={GID}"

try:
    df = pd.read_csv(url)
    print(f" Done {len(df)} reading data...\n")
except Exception as e:
    print(f" Error: {e}")
    df = None

def generate_it_solution(row):
    kategori = row.get('KATEGORI', '')
    intent = row.get('INTENT/TRIGGER', '')
    result_text = row.get('RESULT', '')

    if pd.isna(result_text) or str(result_text).strip() == "":
        return ""

    system_prompt = (
        "You are an expert IT Service Desk automation assistant. "
        "Your task is to transform IT resolution logs into a single, formal, concise, "
        "and instructive solution sentence in English. Do not include any conversational filler, "
        "preamble, or explanations. Output ONLY the final solution sentence. "
        "For example, Analyze the root cause, break the issue into manageable parts, evaluate potential solutions, and implement the best fix."
    )

    user_content = (
        f"Category: {kategori}\n"
        f"Trigger/Intent: {intent}\n"
        f"Resolution Log: {result_text}\n\n"
        f"Instructional Solution:"
    )

    try:
        completion = client.chat.completions.create(
            model="llama-3.3-70b-versatile",
            messages=[
                {"role": "system", "content": system_prompt},
                {"role": "user", "content": user_content}
            ],
            temperature=0.1,
            max_tokens=60
        )
        output_solution = completion.choices[0].message.content.strip()

        if output_solution.startswith('"') and output_solution.endswith('"'):
            output_solution = output_solution[1:-1]

        print(f" Processing {row.get('ID', 'Data')}: Success -> Filled: '{output_solution}'")
        return output_solution

    except Exception as e:
        print(f" Error processing {row.get('ID', 'Data')}: {e}")
        return "Error generating solution."
if df is not None:
    df['Solution'] = df.apply(generate_it_solution, axis=1)

    print("\n Proses Selesai! Berikut sampel data yang telah terisi:")
    display(df[['ID', 'KATEGORI', 'RESULT', 'Solution']].head())

    df.to_csv("hasil_prediksi_solution.csv", index=False)
    print("\n File cadangan disimpan dengan nama 'hasil_prediksi_solution.csv'")
